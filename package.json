{
  "name": "flotiq.plain-js-template",
  "version": "0.2.3",
  "license": "MIT",
  "author": "Flotiq team <helo@flotiq.com> (https://flotiq.com/)",
  "description": "A plain js example of Flotiq plugin. This plugin changes the rendering of some data in the grid. It renders colorful text properties, bold numbers, and relations as text.",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.js",
    "start": "node esbuild.config.js --watch",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,html,mdx,json,yaml,yml,md}\"",
    "lint": "eslint"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^8.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "esbuild-plugin-eslint": "^0.3.12",
    "esbuild-plugin-inline-import": "^1.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "postcss-url": "^10.1.4",
    "prettier": "^3.9.4"
  },
  "dependencies": {
    "@cospired/i18n-iso-languages": "^4.2.0",
    "chalk": "^5.6.2",
    "deep-equal": "^2.2.3",
    "esbuild-plugin-copy": "^2.1.1",
    "i18next": "^26.3.4"
  }
}
